# ApplyPilot — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Resume ────────────────────────────────────────────────────
# Path to your resume PDF (relative to project root)
RESUME_PATH=resume.pdf

# ── LLM Provider ─────────────────────────────────────────────
# Options: openai | featherless | ollama
LLM_PROVIDER=featherless

# ── Featherless (recommended — free tier, no GPU needed) ──────
# Get your key at https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

# Other non-gated Featherless models:
# FEATHERLESS_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# FEATHERLESS_MODEL=NousResearch/Hermes-3-Llama-3.1-70B

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── Ollama (local, fully private) ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
